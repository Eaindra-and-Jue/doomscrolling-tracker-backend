generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Application {
  id Int @id @default(autoincrement()) 
  name String
  platform String
  package_name String @unique
}

model Task {
  id       Int    @id @default(autoincrement())
  userId   String @map("user_id") @db.Uuid
  title    String
  position Int    @default(0)
}

